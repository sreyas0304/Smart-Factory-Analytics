# ── AWS Credentials ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# ── Kinesis ─────────────────────────────────────────────────────────────────
KINESIS_STREAM_NAME=smart-factory-telemetry

# ── Simulator Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FILE_PATH=logs/simulator.log

# ── Cold Path Lambda ────────────────────────────────────────────────────────
FIREHOSE_CNC=firehose-cnc
FIREHOSE_CONVEYOR=firehose-conveyor
FIREHOSE_TEMPERATURE=firehose-temperature
DLQ_SQS_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/smart-factory-dlq

# ── Databricks Lakehouse (notebook widget defaults, not env vars) ───────────
# CATALOG_NAME=smart-factory-catalog
# BRONZE_SCHEMA=bronze
# SILVER_SCHEMA=silver
# GOLD_SCHEMA=gold
# BASE_S3_PATH=s3://smart-factory-analytics-bucket
